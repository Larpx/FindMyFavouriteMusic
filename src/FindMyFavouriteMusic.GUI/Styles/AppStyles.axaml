<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 颜色令牌 -->
    <Color x:Key="ColorPrimary">#4f46e5</Color>
    <Color x:Key="ColorSecondary">#6366f1</Color>
    <Color x:Key="ColorSuccess">#10b981</Color>
    <Color x:Key="ColorWarning">#f59e0b</Color>
    <Color x:Key="ColorError">#ef4444</Color>

    <Color x:Key="ColorNeutral900">#111827</Color>
    <Color x:Key="ColorNeutral600">#6b7280</Color>
    <Color x:Key="ColorNeutral400">#9ca3af</Color>
    <Color x:Key="ColorNeutral100">#f3f4f6</Color>

    <!-- 画刷 -->
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="BrushSecondary" Color="{StaticResource ColorSecondary}"/>
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorNeutral900}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorNeutral600}"/>
    <SolidColorBrush x:Key="BrushTextTertiary" Color="{StaticResource ColorNeutral400}"/>
    <SolidColorBrush x:Key="BrushBackground" Color="#ffffff"/>
    <SolidColorBrush x:Key="BrushSurface" Color="#f3f4f6"/>

    <!-- 字体大小 -->
    <x:Double x:Key="TextXs">12</x:Double>
    <x:Double x:Key="TextSm">14</x:Double>
    <x:Double x:Key="TextBase">16</x:Double>
    <x:Double x:Key="TextLg">20</x:Double>
    <x:Double x:Key="TextXl">24</x:Double>
    <x:Double x:Key="Text2xl">32</x:Double>

    <!-- 间距 -->
    <x:Double x:Key="Space1">4</x:Double>
    <x:Double x:Key="Space2">8</x:Double>
    <x:Double x:Key="Space3">12</x:Double>
    <x:Double x:Key="Space4">16</x:Double>
    <x:Double x:Key="Space6">24</x:Double>
    <x:Double x:Key="Space8">32</x:Double>
    <x:Double x:Key="Space12">48</x:Double>
    <x:Double x:Key="Space16">64</x:Double>

    <!-- 圆角 -->
    <x:Double x:Key="RadiusSm">6</x:Double>
    <x:Double x:Key="RadiusMd">8</x:Double>

    <!-- 卡片阴影 -->
    <x:Double x:Key="ShadowSmOffsetX">0</x:Double>
    <x:Double x:Key="ShadowSmOffsetY">1</x:Double>

</ResourceDictionary>
